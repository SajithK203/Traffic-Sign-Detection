# ============================================================
#  traffic-sign-detection  —  .gitignore
# ============================================================

# ---------------------------
# Raw datasets (NEVER commit)
# ---------------------------
data/raw/

# Processed images are too large for GitHub (~1.5 GB) — share via Google Drive
# Label files (.txt), split summary, and verify images ARE committed (small)
data/processed/**/*.jpg
data/processed/**/*.png
data/processed/**/*.ppm

# Archive formats
*.zip
*.tar.gz
*.tar
*.7z

# ---------------------------
# Model weights & checkpoints
# ---------------------------
results/checkpoints/
*.pt
*.pth
*.onnx
*.torchscript
*.engine
*.tflite
runs/

# ---------------------------
# Python environment
# ---------------------------
venv/
env/
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
*.so

# ---------------------------
# Jupyter
# ---------------------------
.ipynb_checkpoints/

# ---------------------------
# Experiment tracking
# ---------------------------
wandb/
mlruns/
lightning_logs/
tensorboard_logs/
*.tfevents.*

# ---------------------------
# Large output files
# ---------------------------
results/qualitative_examples/*.mp4
results/qualitative_examples/*.avi
*.mp4
*.avi

# ---------------------------
# IDE / Editor
# ---------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---------------------------
# OS
# ---------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ---------------------------
# Misc
# ---------------------------
*.log
*.tmp
*.bak
*.swp
.env

venv_gpu/
*.cache
